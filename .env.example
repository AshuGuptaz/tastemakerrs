# =============================================================
# The Taste Makerrs — Environment Variables (sample)
# Copy to `.env.local` for local dev and fill in real keys.
# =============================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME="The Taste Makerrs"

# ---- MongoDB ----
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.mongodb.net/tastemakerrs?retryWrites=true&w=majority"

# ---- Razorpay (primary, India) ----
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# ---- Stripe (fallback / international) ----
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"

# ---- Admin ----
# bcrypt hash of the admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password',10))"
ADMIN_EMAIL="admin@thetastemakerrs.com"
ADMIN_PASSWORD_HASH="$2a$10$replace_with_real_hash"
ADMIN_JWT_SECRET="replace-with-a-long-random-string"

# ---- Optional: image upload (Cloudinary) ----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
